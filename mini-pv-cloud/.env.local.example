MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=solarcart
INTERNAL_LOG_SECRET=replace-with-long-random-string

# Password gate ($0 "only me") — pick a strong SITE_PASSWORD; AUTH_SECRET signs the login cookie (different string)
SITE_PASSWORD=your-strong-password-here
AUTH_SECRET=generate-another-long-random-string-different-from-above

# Cloudflare tunnel base (HTTPS, no trailing slash) → Pi Node-RED :1880
COMMAND_TUNNEL_URL=https://your-subdomain.trycloudflare.com
